# AutoHisob backend env namunasi — haqiqiy qiymatlarni .env ga qo'ying (.env git'ga tushmaydi)

# --- Asosiy ---
NODE_ENV=development
PORT=3001

# --- Database ---
# Misol: postgresql://user:pass@localhost:5432/avtohisob?schema=public
DATABASE_URL=

# --- JWT ---
# openssl rand -hex 64 bilan generatsiya qiling
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d

# --- CORS ---
# Production da vergul bilan ajratilgan originlar (masalan: https://app.example.com,https://www.example.com)
CORS_ORIGIN=

# --- OpenAI (meter/fuel AI) ---
OPENAI_API_KEY=

# --- Email (parol tiklash) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Telegram bot (markaziy, butun SaaS uchun bitta bot) ---
# BotFather'da bot yaratib token oling: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# --- Haydovchi boti (yakka haydovchilar uchun alohida bot) ---
DRIVER_BOT_TOKEN=

# --- Auto-seed (faqat production birinchi ishga tushishda) ---
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# --- EkoHisob moduli ---
# JWT_SECRET dan foydalaniladi (alohida kalit kerak emas)
# EkoHisob dala xodimlar uchun alohida Telegram bot
EKO_FIELD_BOT_TOKEN=

# Texnik parvarish boti (haydovchiga davriy vazifa eslatmalari)
CARE_BOT_TOKEN=

# --- SMS (Eskiz.uz) — self-registration uchun ---
# Bo'sh qoldirilsa dev-rejim: SMS yuborilmaydi, kod konsolda/javobda ko'rinadi.
# Eskiz.uz dan hisob oching va quyidagilarni to'ldiring:
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546
