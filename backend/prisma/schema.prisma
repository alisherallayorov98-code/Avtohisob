  oilChange         Boolean  @default(true)
  fuelAnomaly       Boolean  @default(true)
  sparePart         Boolean  @default(true)
  maintenance       Boolean  @default(true)
  monthlyInspection Boolean  @default(true)
  // Yangi avto-broadcastlar
  dailySummary      Boolean  @default(true) // Kunlik xulosa (08:00)
  weeklySummary     Boolean  @default(true) // Haftalik xulosa (Du 08:30)
  pendingApproval   Boolean  @default(true) // Tasdiqlash eslatmasi (09:00)
  // Quiet hours (sukut soatlari) — masalan 22:00-07:00 oraliqda Telegram xabar kelmasin
  // 0..23 (UZT bo'yicha). null = yoqilmagan
  quietStart        Int?
  quietEnd          Int?
  branchIds         String[] // bo'sh = barcha filiallar
  vehicleIds        String[] // bo'sh = barcha mashinalar
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_notification_prefs")
}

// Anti-spam: bir xil ogohlantirish 24 soat ichida 1 marta yuborilsin.
// Kalit: userId + alertType + targetKey (vehicleId yoki boshqa). 24 soat o'tgach yangi key.
model TelegramAlertDedupe {
  id        String   @id @default(uuid())
  userId    String
  alertType String // 'insurance', 'fuelAnomaly' va h.k.
  targetKey String // vehicleId yoki boshqa unikal kalit
  sentAt    DateTime @default(now())

  @@unique([userId, alertType, targetKey])
  @@index([sentAt])
  @@map("telegram_alert_dedupe")
}

// Sozlamalar sahifasida "Telegram ulash" bosilganda beriladigan qisqa muddatli token.
// Foydalanuvchi https://t.me/<bot>?start=<token> havolasi orqali botga o'tadi.
model TelegramLinkToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("telegram_link_tokens")
}

// ─── Ehtiyot qism qaytarish ───────────────────────────────────────────────────
model SparePartReturn {
  id             String    @id @default(uuid())
  maintenanceId  String? // qaysi ta'mirlash yozuviga bog'liq (ixtiyoriy)
  vehicleId      String?
  warehouseId    String // qaysi ombor hisobiga qaytariladi
  branchId       String // filial (audit uchun)
  returnedById   String // kim qaytarmoqda
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  status         String    @default("pending_approval") // pending_approval | approved | rejected
  returnDate     DateTime  @default(now())
  reason         String // sabab — MAJBURIY
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  maintenance MaintenanceRecord?        @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  returnedBy  User                      @relation("ReturnCreatedBy", fields: [returnedById], references: [id])
  approvedBy  User?                     @relation("ReturnApprovedBy", fields: [approvedById], references: [id])
  items       SparePartReturnItem[]
  evidence    SparePartReturnEvidence[]

  @@index([status])
  @@index([branchId])
  @@index([maintenanceId])
  @@map("spare_part_returns")
}

model SparePartReturnItem {
  id          String   @id @default(uuid())
  returnId    String
  sparePartId String
  warehouseId String
  quantity    Int
  unitCost    Decimal  @default(0)
  createdAt   DateTime @default(now())

  return    SparePartReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  sparePart SparePart       @relation(fields: [sparePartId], references: [id])

  @@index([returnId])
  @@map("spare_part_return_items")
}

model SparePartReturnEvidence {
  id            String   @id @default(uuid())
  returnId      String
  fileUrl       String
  fileSizeBytes Int      @default(0)
  uploadedById  String?
  createdAt     DateTime @default(now())

  return SparePartReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("spare_part_return_evidence")
}

// ─── Eski qism qarzi (Old Part Debt) ─────────────────────────────────────────
// Yangi qism o'rnatilganda eski qism avtomatik "qarz" bo'ladi.
// Xodim foto yuboradi yoki filialni olib keladi → admin tasdiqlaydi → qarz yechiladi.

model OldPartDebt {
  id              String    @id @default(uuid())
  maintenanceId   String
  vehicleId       String
  vehicleLabel    String    // "30 597 OAA - ISUZU" — denormalized
  workerId        String    // maintenance.performedById
  workerName      String    // denormalized
  branchId        String
  sparePartId     String
  sparePartName   String    // denormalized
  quantity        Int

  // open → submitted (xodim yubordi) → cleared (admin tasdiqladi) | rejected (admin rad etdi → open ga qaytadi)
  status          String    @default("open")

  // Xodim tomonidan topshirish
  submittedAt     DateTime?
  submissionNote  String?
  deliveryMethod  String?   // "photo" | "physical"

  // Admin qarori
  approvedAt      DateTime?
  approvedById    String?
  rejectedReason  String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  maintenance MaintenanceRecord     @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  worker      User                  @relation("OldPartDebtWorker", fields: [workerId], references: [id])
  approvedBy  User?                 @relation("OldPartDebtApprover", fields: [approvedById], references: [id])
  evidence    OldPartDebtEvidence[]

  @@index([status])
  @@index([workerId])
  @@index([branchId])
  @@index([maintenanceId])
  @@map("old_part_debts")
}

model OldPartDebtEvidence {
  id            String   @id @default(uuid())
  debtId        String
  fileUrl       String
  fileSizeBytes Int      @default(0)
  uploadedById  String?
  createdAt     DateTime @default(now())

  debt OldPartDebt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
  @@map("old_part_debt_evidence")
}

// ─── Toza-Hudud moduli ─────────────────────────────────────────────────────

model ThRegion {
  id             String       @id @default(uuid())
  name           String
  organizationId String // SaaS multi-tenant: tashkilot doirasida izolyatsiya
  createdAt      DateTime     @default(now())
  districts      ThDistrict[]

  @@index([organizationId])
  @@map("th_regions")
}

model ThDistrict {
  id             String   @id @default(uuid())
  name           String
  regionId       String
  organizationId String // ThRegion.organizationId bilan moslangan (tezkor filtr uchun)
  createdAt      DateTime @default(now())
  region         ThRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)
  mfys           ThMfy[]

  @@index([regionId])
  @@index([organizationId])
  @@map("th_districts")
}

model ThMfy {
  id             String          @id @default(uuid())
  name           String
  gpsZoneName    String? // SmartGPS dagi geozona nomi (qo'lda moslashtirish — agar saytdagi nom GPS dagi nom bilan farq qilsa)
  districtId     String
  organizationId String // ThDistrict.organizationId bilan moslangan (tezkor filtr uchun)
  polygon        Json?
  createdAt      DateTime        @default(now())
  district       ThDistrict      @relation(fields: [districtId], references: [id], onDelete: Cascade)
  schedules      ThSchedule[]
  serviceTrips   ThServiceTrip[]
  containers     ThContainer[]
  streets        ThMfyStreet[]

  @@index([districtId])
  @@index([organizationId])
  @@map("th_mfys")
}

model ThContainer {
  id             String             @id @default(uuid())
  name           String
  gpsZoneName    String? // SmartGPS dagi circle zona nomi (sinx uchun)
  organizationId String
  mfyId          String? // Agar tegishli MFY ma'lum bo'lsa
  latitude       Float
  longitude      Float
  radiusM        Float // Konteyner radiusi metrda (SmartGPS dan keladi yoki qo'lda)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  mfy            ThMfy?             @relation(fields: [mfyId], references: [id], onDelete: SetNull)
  visits         ThContainerVisit[]

  @@index([organizationId])
  @@index([mfyId])
  @@map("th_containers")
}

// Konteyner tashriflari — mashina konteyner radiusiga kirib chiqqan har bir holat.
// thMonitor.runDailyMonitoring tomonidan har kuni tahlil qilinadi.
model ThContainerVisit {
  id          String      @id @default(uuid())
  vehicleId   String
  containerId String
  date        DateTime // kun (UTC 00:00)
  arrivedAt   DateTime // radiusga kirgan vaqt
  leftAt      DateTime? // radiusdan chiqqan vaqt (null = kun oxiriga ichida qoldi)
  durationMin Int? // ichida qolgan vaqt minutda
  createdAt   DateTime    @default(now())
  container   ThContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([containerId])
  @@index([date])
  @@index([vehicleId, date])
  @@map("th_container_visits")
}

model ThLandfill {
  id             String           @id @default(uuid())
  name           String
  location       String?
  organizationId String // SaaS multi-tenant
  polygon        Json?
  createdAt      DateTime         @default(now())
  trips          ThLandfillTrip[]

  @@index([organizationId])
  @@map("th_landfills")
}

model ThSchedule {
  id        String   @id @default(uuid())
  vehicleId String
  mfyId     String
  dayOfWeek Int[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mfy ThMfy @relation(fields: [mfyId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, mfyId])
  @@index([vehicleId])
  @@index([mfyId])
  @@map("th_schedules")
}

model ThServiceTrip {
  id          String    @id @default(uuid())
  vehicleId   String
  mfyId       String
  date        DateTime  @db.Date
  status      String    @default("not_visited") // visited | not_visited | no_gps | no_polygon
  enteredAt   DateTime?
  exitedAt    DateTime?
  maxSpeedKmh Float?
  suspicious   Boolean   @default(false)
  coveragePct  Int?      // 0-100, grid usulida hisoblangan MFY qamrovi %
  anomalyFlags   Json?     // {tooFast, timeTooShort, linearTrack, edgeOnly}
  timeInsideMin  Int?      // MFY ichida o'tkazilgan vaqt (daqiqa)
  trackSnapshot  Json?     // thinned track (max 500 points) xaritada ko'rsatish uchun
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  mfy ThMfy @relation(fields: [mfyId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, mfyId, date])
  @@index([vehicleId])
  @@index([mfyId])
  @@index([date])
  @@map("th_service_trips")
}

model ThLandfillTrip {
  id          String    @id @default(uuid())
  vehicleId   String
  landfillId  String
  date        DateTime  @db.Date
  arrivedAt   DateTime?
  leftAt      DateTime?
  durationMin Int?
  createdAt   DateTime  @default(now())

  landfill ThLandfill @relation(fields: [landfillId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([landfillId])
  @@index([date])
  @@map("th_landfill_trips")
}

model ThSetting {
  id                       String   @id @default(uuid())
  organizationId           String   @unique
  suspiciousSpeedKmh       Int      @default(25)
  autoMonitorEnabled       Boolean  @default(true)
  coverageGreenPct         Int      @default(80)
  coverageYellowPct        Int      @default(50)
  // Telegram bildirishnomalar
  notifyOnMonitorComplete  Boolean  @default(true)
  notifyOnLowCoverage      Boolean  @default(true)
  notifyMinCoveragePct     Int      @default(60)
  // Haydovchi kirish tizimi
  driverAccessEnabled      Boolean  @default(false)
  driverPinHash            String?
  // GPS monitoring parametrlari (sozlanmagan = default)
  gridCellM                Int      @default(35)
  coverageRadiusM          Int      @default(40)
  minVisitSec              Int      @default(30)
  monitorStartHour         Int      @default(6)
  monitorEndHour           Int      @default(18)
  // Ish vaqti nazorati
  workStartTime            String   @default("08:00")  // "HH:MM" format
  workEndTime              String   @default("18:00")  // "HH:MM" format
  workTrackingEnabled      Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("th_settings")
}

// Haydovchi haftalik/oylik statistika va reyting
model ThDriverStat {
  id               String   @id @default(cuid())
  vehicleId        String   @unique
  weekCoveragePct  Int      @default(0)
  monthCoveragePct Int      @default(0)
  streak           Int      @default(0)  // ketma-ket 80%+ kun soni
  rank             Int?
  weekVisited      Int      @default(0)
  weekTotal        Int      @default(0)
  updatedAt        DateTime @updatedAt

  @@index([weekCoveragePct])
  @@map("th_driver_stats")
}

// Bayram kunlari — shu kunlarda avtomatik monitoring o'tkazib yuboriladi
// va haydovchilarga jadval yuborilmaydi.
model ThHoliday {
  id             String   @id @default(cuid())
  organizationId String
  date           DateTime @db.Date
  name           String   // "Yangi yil", "Navro'z" va h.k.
  createdAt      DateTime @default(now())

  @@unique([organizationId, date])
  @@index([organizationId])
  @@index([date])
  @@map("th_holidays")
}

// OpenStreetMap dan olingan ko'cha segmentlari — MFY ichidagi yo'llar
model ThMfyStreet {
  id        String   @id @default(cuid())
  mfyId     String
  osmWayId  String   // OSM way ID
  name      String?  // Ko'cha nomi (uz/ru)
  highway   String?  // Ko'cha turi: residential, service, primary...
  geometry  Json     // [[lat, lon], ...] polyline nuqtalari
  lengthM   Float    @default(0) // Ko'cha uzunligi metrda
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mfy ThMfy @relation(fields: [mfyId], references: [id], onDelete: Cascade)

  @@unique([mfyId, osmWayId])
  @@index([mfyId])
  @@map("th_mfy_streets")
}

// AI Coverage Fingerprint: har oy uchun vehicle+MFY kataklar "xotirasi"
// 6 oylik tarixdan qaysi ko'chalar odatda qoplanishini o'rganadi.
model ThCoverageFingerprint {
  id         String   @id @default(cuid())
  vehicleId  String
  mfyId      String
  month      String   // "2026-01" format
  cells           Json     // [{lat, lon}] — shu oyda kamida bir marta qoplangan kataklar
  cellFrequencies Json?    // [[lat_int, lon_int, count]] — barcha oylar bo'yicha chastota
  pointCount      Int      @default(0) // GPS nuqtalar soni (kalibr/debug)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([vehicleId, mfyId, month])
  @@index([vehicleId])
  @@index([mfyId])
  @@map("th_coverage_fingerprints")
}

// Kunlik ish vaqti sessiyasi: mashina ertalab nechida ish boshladi, kechqurun nechida tugatdi
model ThWorkSession {
  id             String   @id @default(cuid())
  organizationId String
  vehicleId      String
  date           DateTime @db.Date        // Kun (UTC 00:00)
  firstGpsAt     DateTime?               // Birinchi GPS signali (ish boshlash)
  lastGpsAt      DateTime?               // Oxirgi GPS signali (ish tugatish)
  durationMin    Int      @default(0)    // Ish davomiyligi (daqiqa)
  // Kutilgan vaqtlarga nisbatan holat
  startStatus    String   @default("absent") // early | on_time | late | absent
  endStatus      String?                     // early | on_time | late | null(absent)
  lateStartMin   Int      @default(0)    // Necha daqiqa kech keldi (0 = kelmadi yoki o'z vaqtida)
  earlyEndMin    Int      @default(0)    // Necha daqiqa erta ketdi
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([vehicleId, date])
  @@index([organizationId, date])
  @@index([vehicleId])
  @@map("th_work_sessions")
}

// Universal arxiv: o'chirilgan ma'lumotlar shu yerga snapshot sifatida yoziladi
// va kerak bo'lsa qaytadan tiklash mumkin. Eskilar 90 kundan keyin avto-tozalanadi.
model Archive {
  id             String    @id @default(uuid())
  // Modul/jadval nomi: 'MaintenanceRecord', 'Vehicle', 'Expense' va h.k.
  entityType     String
  // Original yozuv ID si (tiklashda ishlatish uchun)
  entityId       String
  // Foydalanuvchiga ko'rsatish uchun yorliq: "01-A123 ISUZU", "29-apr ta'mir 280k" va h.k.
  entityLabel    String
  // To'liq yozuv + bog'liq ma'lumotlar (items, evidence va h.k.) JSON shaklida
  snapshot       Json
  // Multi-tenant izolatsiya
  organizationId String?
  // Kim qachon o'chirgan
  deletedById    String
  deletedAt      DateTime  @default(now())
  // Ixtiyoriy: nima uchun o'chirilgan (kelajakda kiritish uchun)
  reason         String?
  // Avto-tozalash sanasi (default: 90 kun)
  expiresAt      DateTime
  // Tiklab bo'lganmi (qaytadan urinmaslik uchun)
  isRestored     Boolean   @default(false)
  restoredAt     DateTime?

  deletedBy User @relation("ArchiveDeletedBy", fields: [deletedById], references: [id])

  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([expiresAt])
  @@map("archive")
}

// (OrgSetting singular model OrgSettings (plural) ga birlashtirildi —
//  bir xil "org_settings" table'ga map qilish kollizionini bartaraf etish uchun.
//  Hamma yangi maydonlar (simplifiedView, hiddenFeatures, va h.k.) endi OrgSettings'da.)

// Landing'dan kelgan ariza (lead). Hech qaysi org'ga bog'lanmagan — public.
// Super_admin admin panel'dan ko'radi va qo'lda akkaunt yaratadi.
model Lead {
  id               String    @id @default(uuid())
  // Kontakt
  fullName         String
  phone            String
  email            String?
  organizationName String?
  fleetSize        Int? // taxminiy avtomobillar soni
  message          String?
  // Manba va tracking
  source           String    @default("landing") // landing, telegram, va h.k.
  referrer         String? // qaysi sahifadan kelgan
  ipAddress        String?
  userAgent        String?
  // Status
  status           String    @default("new") // new, contacted, converted, rejected, spam
  notes            String? // ichki izoh (super_admin ko'radi)
  contactedAt      DateTime?
  convertedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

// ── Yakka haydovchi bot modellari ─────────────────────────────────────────────

model DriverBotUser {
  id              String   @id @default(uuid())
  chatId          String   @unique
  firstName       String?
  lastName        String?
  username        String?
  fuelPrice       Int      @default(12000)
  fuelPer100km    Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trips    DriverTrip[]
  expenses DriverExpense[]

  @@map("driver_bot_users")
}

model DriverTrip {
  id          String    @id @default(uuid())
  driverId    String
  fromCity    String
  toCity      String
  distanceKm  Int
  cargoPrice  Int
  fuelCost    Int
  tollCost    Int       @default(0)
  otherCost   Int       @default(0)
  netProfit   Int
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  status      String    @default("completed")

  driver DriverBotUser @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([startedAt])
  @@map("driver_trips")
}

model DriverExpense {
  id          String   @id @default(uuid())
  driverId    String
  type        String
  amount      Int
  description String?
  createdAt   DateTime @default(now())

  driver DriverBotUser @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([createdAt])
  @@map("driver_expenses")
}

// ── EkoHisob moduli ───────────────────────────────────────────────────────────

model EkoHisobUser {
  id           String   @id @default(uuid())
  email        String
  passwordHash String
  fullName     String
  role         String   @default("inspector") // admin | inspector | supervisor (boshliq — read-only nazoratchi)
  isActive     Boolean  @default(true)
  orgId        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  districts  EkoHisobUserDistrict[]
  payments   EkoHisobPayment[]
  receipts   EkoHisobReceipt[]
  botLink    EkoHisobBotLink?
  linkTokens EkoHisobLinkToken[]
  plans      EkoHisobPlan[]

  @@unique([email, orgId])
  @@index([orgId])
  @@map("ekohisob_users")
}

model EkoHisobUserDistrict {
  id         String @id @default(uuid())
  userId     String
  districtId String

  user     EkoHisobUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  district EkoHisobDistrict @relation(fields: [districtId], references: [id], onDelete: Cascade)

  @@unique([userId, districtId])
  @@map("ekohisob_user_districts")
}

model EkoHisobDistrict {
  id        String   @id @default(uuid())
  name      String
  orgId     String
  createdAt DateTime @default(now())

  users    EkoHisobUserDistrict[]
  mahallas EkoHisobMahalla[]
  entities EkoHisobLegalEntity[]

  @@index([orgId])
  @@map("ekohisob_districts")
}

model EkoHisobMahalla {
  id         String   @id @default(uuid())
  name       String
  districtId String
  createdAt  DateTime @default(now())

  district EkoHisobDistrict    @relation(fields: [districtId], references: [id], onDelete: Cascade)
  entities EkoHisobLegalEntity[]

  @@index([districtId])
  @@map("ekohisob_mahallas")
}

model EkoHisobLegalEntity {
  id          String   @id @default(uuid())
  name        String
  stir        String?
  code        String?
  address     String?
  lat         Float?
  lon         Float?
  phone       String?
  contactName String?
  districtId  String
  mahallId    String?
  orgId       String
  status      String   @default("active") // active | blacklisted | inactive | draft
  monthlyFee  Int      @default(0)
  // To'lov rejimi: 'variable' (har oy har xil) | 'monthly_fixed' (belgilangan oylik,
  // avto-hisob) | 'talon' (bajarilgan ish/kub asosida, oylik yo'q).
  billingMode      String   @default("variable")
  // 'talon' rejimi uchun: bir kub (chiqindi) narxi. Talon summasi = kub × cubicPrice.
  cubicPrice       Int      @default(0)
  // Shartnoma boshlangan oy "YYYY-MM" — hisoblar shu oydan boshlab yoziladi (null = joriy oy)
  contractStartMonth String?
  contractNumber     String?
  // Eskalatsiya darajasi (cron har kuni yangilaydi):
  // current | warning (1 oy) | overdue (2 oy) | critical (3+ oy) | blacklisted
  debtLevel  String   @default("current")
  createdBy  String?              // kim kiritdi (EkoHisobUser id) — plan progressi uchun
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  district  EkoHisobDistrict @relation(fields: [districtId], references: [id])
  mahalla   EkoHisobMahalla? @relation(fields: [mahallId], references: [id])
  payments  EkoHisobPayment[]
  charges   EkoHisobCharge[]
  blacklist EkoHisobBlacklist?
  receipts  EkoHisobReceipt[]
  talons    EkoHisobTalon[]

  @@index([districtId])
  @@index([orgId])
  @@index([stir])
  @@index([status])
  @@index([billingMode])
  @@map("ekohisob_legal_entities")
}

// Talon — billingMode='talon' tashkilotlar uchun. Oylik belgilangan to'lov yo'q —
// haq bajarilgan ish (chiqindi hajmi) asosida. Tashkilotga bir kub narxi (cubicPrice)
// belgilanadi. Har xizmat: sana + kub → summa = kub × narx, qarzga qo'shiladi.
// Inspektor (botdan) yoki admin (saytdan) qo'shadi.
model EkoHisobTalon {
  id        String   @id @default(uuid())
  entityId  String
  orgId     String
  volume    Float                // bajarilgan ish hajmi (kub metr)
  amount    Int                  // summa = volume × tashkilot cubicPrice
  date      DateTime @db.Date     // ish bajarilgan sana
  note      String?              // izoh (qanday ish)
  createdBy String?              // EkoHisobUser id (inspektor) yoki null (admin)
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())

  entity EkoHisobLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId])
  @@index([orgId])
  @@index([date])
  @@map("ekohisob_talons")
}

model EkoHisobPayment {
  id         String   @id @default(uuid())
  entityId   String
  month      String
  amount     Int
  paidAt     DateTime @default(now())
  receivedBy String
  note       String?

  entity   EkoHisobLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  receiver EkoHisobUser        @relation(fields: [receivedBy], references: [id])
  receipt  EkoHisobReceipt?

  // Qisman to'lov: bir oyga bir necha to'lov yozuvi bo'lishi mumkin.
  // Umumiy holat (qancha to'langan/qolgan) EkoHisobCharge.paidAmount da saqlanadi.
  @@index([entityId, month])
  @@index([entityId])
  @@index([month])
  @@map("ekohisob_payments")
}

// Oylik hisob (charge) — FAQAT billingMode='monthly_fixed' tashkilotlar uchun
// har oy avtomatik (yoki qo'lda "hisoblarni yarat") yoziladi. Qarz = ochiq/qisman
// charge'lar yig'indisi. 'variable' tashkilotlarda charge yo'q (qarz to'planmaydi).
model EkoHisobCharge {
  id             String   @id @default(uuid())
  entityId       String
  month          String // "YYYY-MM"
  expectedAmount Int
  paidAmount     Int      @default(0)
  status         String   @default("open") // open | partial | paid
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  entity EkoHisobLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, month])
  @@index([entityId])
  @@index([month])
  @@index([status])
  @@map("ekohisob_charges")
}

model EkoHisobBlacklist {
  id         String   @id @default(uuid())
  entityId   String   @unique
  reason     String
  addedAt    DateTime @default(now())
  addedBy    String
  govOrgName String?
  govCaseId  String?
  status     String   @default("active") // active | resolved

  entity EkoHisobLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("ekohisob_blacklist")
}

// Dala xodimini Telegram bilan bog'lovchi jadval
model EkoHisobBotLink {
  id          String   @id @default(uuid())
  chatId      String   @unique
  userId      String   @unique
  // Ulangan Telegram hisobi (kim ulangani) — admin nazorati uchun
  tgUsername  String?
  tgFirstName String?
  lang        String   @default("latin") // latin | cyrillic — bot matni tili
  linkedAt    DateTime @default(now())

  user EkoHisobUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ekohisob_bot_links")
}

// Kvitansiya — har to'lovga ketma-ket raqam bilan chiqariladi
model EkoHisobReceipt {
  id            String   @id @default(uuid())
  receiptNumber String   // "EKO-2026-00001"
  orgId         String
  entityId      String
  paymentId     String   @unique
  month         String
  amount        Int
  issuedBy      String
  issuedAt      DateTime @default(now())

  entity  EkoHisobLegalEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  payment EkoHisobPayment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  issuer  EkoHisobUser        @relation(fields: [issuedBy], references: [id])

  @@unique([orgId, receiptNumber])
  @@index([entityId])
  @@index([orgId])
  @@map("ekohisob_receipts")
}

// Ketma-ket raqam uchun counter (orgId bo'yicha, har yil sifirlanadi)
model EkoHisobReceiptSeq {
  orgId   String @id
  lastNum Int    @default(0)
  year    Int    @default(0)

  @@map("ekohisob_receipt_seq")
}

// Bir martalik token — admin yaratadi, dala xodimi /start TOKEN bilan ishlatadi
model EkoHisobLinkToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user EkoHisobUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("ekohisob_link_tokens")
}

// SMS eslatma jurnali — qarzdorga yuborilgan SMS lar (Eskiz.uz orqali).
// Billing/audit uchun: kim, qachon, qancha SMS yuborilgani saqlanadi.
model EkoHisobSmsLog {
  id            String   @id @default(uuid())
  orgId         String
  entityId      String?              // tashkilot (qarzdor) — null bo'lishi mumkin (umumiy)
  phone         String               // yuborilgan raqam (998XXXXXXXXX)
  message       String               // SMS matni
  status        String   @default("sent") // sent | failed
  providerMsgId String?              // Eskiz message id (yetkazib berishni kuzatish)
  error         String?              // xato bo'lsa sababi
  sentBy        String?              // EkoHisobUser id (qo'lda yuborgan) yoki null (avto/cron)
  createdAt     DateTime @default(now())

  @@index([orgId])
  @@index([entityId])
  @@index([createdAt])
  @@map("ekohisob_sms_logs")
}

// Kunlik plan (topshiriq) — supervisor/admin inspektorga beradi.
// Hozir: type='new_entity' (kuniga nechta tashkilot kiritish). Progress avtomatik
// hisoblanadi (entity.createdBy + sana) — saqlanmaydi.
model EkoHisobPlan {
  id           String   @id @default(uuid())
  orgId        String
  inspectorId  String                // kimga (EkoHisobUser)
  assignedById String?               // kim bergan (supervisor/admin EkoHisobUser)
  date         DateTime @db.Date      // qaysi kun uchun
  targetCount  Int                    // maqsad (masalan 20 ta tashkilot)
  type         String   @default("new_entity") // new_entity | (kelajakda: payment, ...)
  note         String?
  createdAt    DateTime @default(now())

  inspector EkoHisobUser @relation(fields: [inspectorId], references: [id], onDelete: Cascade)

  @@unique([inspectorId, date, type]) // bir kun, bir inspektor, bir tur — bitta plan
  @@index([orgId])
  @@index([inspectorId])
  @@index([date])
  @@map("ekohisob_plans")
}

// ── Mashina texnik parvarishi (preventive care) ──────────────────────────────
// Davriy vazifalar: havo filtrini tozalash, xodovoy smazka va h.k. Admin yaratadi,
// keyingi bosqichda bot haydovchiga belgilangan kunlarda eslatadi (rasm/video isboti).
model VehicleCareTask {
  id             String   @id @default(uuid())
  organizationId String
  name           String              // "Havo filtrini tozalash"
  description    String?
  weekdays       Int[]               // haftaning kunlari: 0=Yakshanba .. 6=Shanba (masalan [3,6])
  scope          String   @default("all") // all | branch | vehicles
  branchId       String?             // scope=branch uchun
  vehicleIds     String[]            // scope=vehicles uchun
  isActive       Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("vehicle_care_tasks")
}
