// Tashkilot doirasidagi sozlamalar — yagona model.
// Avval ikki alohida model (OrgSettings + OrgSetting) ikkalasi ham
// "org_settings" jadvaliga map qilingan edi va Prisma validation xato berardi.
// Endi barcha sozlamalar shu yerda: yog' xizmati, Telegram, soddalashtirilgan ko'rinish, hidden features.
model OrgSettings {
  orgId            String    @id
  oilIntervalKm    Int       @default(7000)
  oilWarningKm     Int       @default(500)
  telegramBotToken String?
  telegramChatId   String?
  // Soddalashtirilgan ko'rinish — norasmiy yozuvlar butun saytda yashirin
  simplifiedView   Boolean   @default(false)
  simplifiedAt     DateTime?
  toggledById      String?
  // Yashirilgan modullar/funksiyalar (key list)
  hiddenFeatures   String[]  @default([])
  // ─── Bak nazorati anomaliya threshold'lari (mijozga moslashtirish) ─────────
  // Default qiymatlar fuelAnomalyDetector.ts'dan olingan.
  // Karyer mashinalari (katta sarf) uchun chegaralarni ko'tarish mumkin.
  fuelTheftRateLPerMin Float @default(1.0)   // Sliv tezligi (L/daq) — 1.0 = oddiy diesel sarfdan yuqori
  fuelTheftMinDropL    Float @default(5)     // Minimal pasayish (L) — kichik o'zgarishlarni shovqin sifatida o'tkazib yuboradi
  fuelTheftMaxGapMin   Float @default(60)    // Maks vaqt oraligi (daq)
  fuelRefuelMinRiseL   Float @default(5)     // Zapravka minimal ko'tarilishi (L)
  fuelRefuelMaxGapMin  Float @default(60)    // Zapravka maksimal vaqt oraligi (daq)
  fuelRecordWindowMin  Float @default(30)    // FuelRecord cross-check oynasi (±daq)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("org_settings")
}

