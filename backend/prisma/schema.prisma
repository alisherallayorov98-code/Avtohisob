generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  manager
  branch_manager
  operator
}

enum FuelType {
  petrol
  diesel
  gas
  electric
  hybrid
}

enum VehicleStatus {
  active
  maintenance
  inactive
}

enum TransferStatus {
  pending
  approved
  shipped
  received
}

model User {
  id                        String    @id @default(uuid())
  email                     String    @unique
  phone                     String?   @unique
  passwordHash              String
  fullName                  String
  role                      UserRole
  branchId                  String?
  isActive                  Boolean   @default(true)
  lastLoginAt               DateTime?
  passwordChangedAt         DateTime?
  // Email verification
  emailVerified             Boolean   @default(false)
  verificationToken         String?
  verificationTokenExpiry   DateTime?
  // Password reset
  passwordResetToken        String?
  passwordResetTokenExpiry  DateTime?
  // 2FA (TOTP)
  twoFactorEnabled          Boolean   @default(false)
  twoFactorSecret           String?
  // Billing ceiling: super admin sets this. Admin can only select plans ≤ maxPlanType.
  maxPlanType               PlanType  @default(free)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  branch              Branch?              @relation("UserBranch", fields: [branchId], references: [id])
  managedBranches     Branch[]             @relation("BranchManager")
  maintenanceRecords  MaintenanceRecord[]  @relation("PerformedBy")
  fuelRecords         FuelRecord[]         @relation("FuelCreatedBy")
  expenses            Expense[]            @relation("ExpenseCreatedBy")
  approvedTransfers   InventoryTransfer[]  @relation("TransferApprovedBy")
  tokenBlacklists     TokenBlacklist[]
  assignedTires       Tire[]               @relation("TireDriver")
  auditLogs           AuditLog[]
  notifications       Notification[]
  savedReports        Report[]             @relation("ReportCreatedBy")
  subscription        Subscription?
  supportTickets      SupportTicket[]
  ticketReplies       TicketReply[]
  drivenWaybills      Waybill[]        @relation("WaybillDriver")
  createdWaybills     Waybill[]        @relation("WaybillCreatedBy")
  supplierPayments    SupplierPayment[] @relation("SupplierPaymentCreatedBy")
  techInspections     TechInspection[] @relation("InspectionInspectedBy")
  engineRecords       EngineRecord[]   @relation("EngineRecordCreator")
  telegramLinks       TelegramLink[]
  telegramLinkTokens  TelegramLinkToken[]
  telegramNotifPref   TelegramNotificationPref?
  shippedBatches      TransferBatch[]      @relation("BatchShippedBy")
  receivedBatches     TransferBatch[]      @relation("BatchReceivedBy")
  createdBatches      TransferBatch[]      @relation("BatchCreatedBy")
  sparePartRequests   SparePartRequest[]   @relation("RequestCreatedBy")
  respondedRequests   SparePartRequest[]   @relation("RequestRespondedBy")
  approvedMaintenance MaintenanceRecord[]  @relation("MaintenanceApprovedBy")
  sparePartReturns    SparePartReturn[]    @relation("ReturnCreatedBy")
  approvedReturns     SparePartReturn[]    @relation("ReturnApprovedBy")

  @@index([role])
  @@index([branchId])
  @@map("users")
}

model Warehouse {
  id        String   @id @default(uuid())
  name      String
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches              Branch[]
  inventory             Inventory[]
  transfersFrom         InventoryTransfer[]  @relation("TransferFrom")
  transfersTo           InventoryTransfer[]  @relation("TransferTo")
  maintenanceRecords    MaintenanceRecord[]  @relation("MaintenanceSourceWarehouse")
  maintenanceItems      MaintenanceItem[]    @relation("MaintenanceItemWarehouse")
  batchesFrom           TransferBatch[]      @relation("BatchFrom")
  batchesTo             TransferBatch[]      @relation("BatchTo")

  @@map("warehouses")
}

model Branch {
  id                String   @id @default(uuid())
  name              String
  location          String
  managerId         String?
  warehouseCapacity Decimal  @default(0)
  contactPhone      String
  isActive          Boolean  @default(true)
  warehouseId       String?
  organizationId    String?
  // Plan assigned by admin to this branch. Null = inherit admin's plan.
  planId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  manager      User?      @relation("BranchManager", fields: [managerId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  plan         Plan?      @relation("BranchPlan", fields: [planId], references: [id], onDelete: SetNull)
  users        User[]     @relation("UserBranch")
  vehicles     Vehicle[]
  waybills     Waybill[]
  organization Branch?    @relation("OrgBranches", fields: [organizationId], references: [id], onDelete: SetNull)
  subBranches  Branch[]   @relation("OrgBranches")

  @@index([organizationId])
  @@map("branches")
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  model              String
  brand              String
  year               Int
  fuelType           FuelType
  branchId           String
  purchaseDate       DateTime
  mileage              Decimal       @default(0)
  engineHours          Decimal?                      // dvigatel soatlari (GPS dan)
  lastGpsSignal        DateTime?                     // oxirgi GPS signal vaqti
  gpsUnitName          String?                       // GPS dagi unit nomi (qo'lda bog'lash)
  oilIntervalKm        Int?                          // motor yog'i almashtirish intervali (km), null = org default
  status               VehicleStatus @default(active)
  notes                String?
  insuranceExpiry      DateTime?
  techInspectionExpiry DateTime?
  createdAt            DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  branch             Branch              @relation(fields: [branchId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  fuelRecords        FuelRecord[]
  expenses           Expense[]
  healthScores       VehicleHealthScore[]
  fuelMetrics        FuelConsumptionMetric[]
  predictions        MaintenancePrediction[]
  anomalies          Anomaly[]
  recommendations    Recommendation[]
  alerts             Alert[]
  tires              Tire[]
  warranties         Warranty[]
  serviceIntervals   ServiceInterval[]
  serviceRecords     ServiceRecord[]
  waybills           Waybill[]
  engineRecords      EngineRecord[]
  techInspections    TechInspection[]
  gpsMileageLogs     GpsMileageLog[]
  tireTrackings      TireTracking[]

  @@index([branchId])
  @@index([status])
  @@index([fuelType])
  @@map("vehicles")
}

model Supplier {
  id             String   @id @default(uuid())
  organizationId String?  // null = global (eski yozuvlar), tashkilotga biriktirilgan
  name           String
  contactPerson  String?
  phone          String
  email          String?
  address        String?
  paymentTerms   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  spareParts         SparePart[]
  maintenanceRecords MaintenanceRecord[]
  fuelRecords        FuelRecord[]
  tires              Tire[]
  payments           SupplierPayment[]

  @@index([organizationId])
  @@map("suppliers")
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String
  amount      Decimal
  // 'invoice' = xarid (biz qarz bo'ldik) | 'payment' = to'lov (biz to'ladik)
  type        String   @default("payment")
  paymentDate DateTime
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy   User     @relation("SupplierPaymentCreatedBy", fields: [createdById], references: [id])

  @@index([supplierId])
  @@map("supplier_payments")
}

model SparePart {
  id             String   @id @default(uuid())
  name           String
  partCode       String   @unique
  category       String
  unitPrice      Decimal
  supplierId     String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  organizationId String?  // null = global (legacy/migration'gacha), org'ga biriktirilgan
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier           Supplier            @relation(fields: [supplierId], references: [id])
  inventories        Inventory[]
  maintenanceRecords MaintenanceRecord[]
  maintenanceItems   MaintenanceItem[]
  transfers          InventoryTransfer[]
  articleCode        ArticleCode?
  statistic          SparePartStatistic?
  requestItems       SparePartRequestItem[]
  returnItems        SparePartReturnItem[]

  @@index([organizationId])
  @@map("spare_parts")
}

model Inventory {
  id               String    @id @default(uuid())
  sparePartId      String
  warehouseId      String
  quantityOnHand   Int       @default(0)
  quantityReserved Int       @default(0)
  reorderLevel     Int       @default(1)
  lastRestockDate  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sparePart SparePart @relation(fields: [sparePartId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([sparePartId, warehouseId])
  @@index([warehouseId])
  @@index([sparePartId])
  @@map("inventory")
}

model MaintenanceRecord {
  id                String      @id @default(uuid())
  vehicleId         String
  sparePartId       String?
  quantityUsed      Int         @default(0)
  sourceWarehouseId String?
  installationDate  DateTime
  installationMileage Int?
  cost              Decimal     @default(0)
  laborCost         Decimal     @default(0)
  workerName        String?
  paymentType       String      @default("cash")
  isPaid            Boolean     @default(true)
  supplierId        String?
  notes             String?
  performedById     String
  // Approval workflow
  status            String      @default("approved") // approved | pending_approval | rejected
  approvedById      String?
  approvedAt        DateTime?
  rejectedReason    String?
  // Telegram OTP evidence upload
  evidenceOtpCode   String?
  evidenceOtpExpiry DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  vehicle          Vehicle              @relation(fields: [vehicleId], references: [id])
  sparePart        SparePart?           @relation(fields: [sparePartId], references: [id])
  sourceWarehouse  Warehouse?           @relation("MaintenanceSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  supplier         Supplier?            @relation(fields: [supplierId], references: [id])
  performedBy      User                 @relation("PerformedBy", fields: [performedById], references: [id])
  approvedBy       User?                @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  items            MaintenanceItem[]
  evidence         MaintenanceEvidence[]
  returns          SparePartReturn[]

  @@index([vehicleId])
  @@index([installationDate])
  @@index([vehicleId, installationDate])
  @@index([sparePartId])
  @@index([status])
  @@map("maintenance_records")
}

model MaintenanceEvidence {
  id            String   @id @default(uuid())
  maintenanceId String
  fileUrl       String
  fileSizeBytes Int      @default(0)
  uploadedById  String?
  createdAt     DateTime @default(now())

  maintenance MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@index([maintenanceId])
  @@map("maintenance_evidence")
}

model MaintenanceItem {
  id            String   @id @default(uuid())
  maintenanceId String
  sparePartId   String
  warehouseId   String?
  quantityUsed  Int      @default(1)
  unitCost      Decimal  @default(0)
  // Tire integration
  isTire        Boolean  @default(false)
  tireSerial    String?
  tirePosition  String?
  tireId        String?  // auto-created Tire id
  createdAt     DateTime @default(now())

  maintenance MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  sparePart   SparePart         @relation(fields: [sparePartId], references: [id])
  warehouse   Warehouse?        @relation("MaintenanceItemWarehouse", fields: [warehouseId], references: [id])

  @@index([maintenanceId])
  @@index([sparePartId])
  @@map("maintenance_items")
}

model FuelRecord {
  id              String   @id @default(uuid())
  vehicleId       String
  fuelType        FuelType
  amountLiters    Decimal
  cost            Decimal
  odometerReading Decimal
  refuelDate      DateTime
  supplierId      String?
  receiptImageUrl String?
  aiExtractedData Json?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle       Vehicle            @relation(fields: [vehicleId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  createdBy     User               @relation("FuelCreatedBy", fields: [createdById], references: [id])
  meterReadings FuelMeterReading[]

  @@index([vehicleId])
  @@index([refuelDate])
  @@index([vehicleId, refuelDate])
  @@index([supplierId])
  @@map("fuel_records")
}

model FuelMeterReading {
  id              String    @id @default(uuid())
  fuelRecordId    String?
  imageUrl        String
  extractedValue  Decimal?
  confidenceScore Decimal?
  rawOcrText      String?
  processedAt     DateTime?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  fuelRecord FuelRecord? @relation(fields: [fuelRecordId], references: [id])

  @@map("fuel_meter_readings")
}

model InventoryTransfer {
  id               String         @id @default(uuid())
  fromWarehouseId  String
  toWarehouseId    String
  sparePartId      String
  quantity         Int
  transferDate     DateTime       @default(now())
  approvedById     String?
  status           TransferStatus @default(pending)
  notes            String?
  batchId          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fromWarehouse Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  sparePart     SparePart      @relation(fields: [sparePartId], references: [id])
  approvedBy    User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  batch         TransferBatch? @relation(fields: [batchId], references: [id])

  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([batchId])
  @@map("inventory_transfers")
}

model TransferBatch {
  id              String   @id @default(uuid())
  documentNumber  String   @unique
  orgId           String
  fromWarehouseId String
  toWarehouseId   String
  requestId       String?
  status          String   @default("pending")
  notes           String?
  shippedAt       DateTime?
  shippedById     String?
  receivedAt      DateTime?
  receivedById    String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fromWarehouse Warehouse         @relation("BatchFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse         @relation("BatchTo", fields: [toWarehouseId], references: [id])
  transfers     InventoryTransfer[]
  request       SparePartRequest? @relation(fields: [requestId], references: [id])
  shippedBy     User?             @relation("BatchShippedBy", fields: [shippedById], references: [id])
  receivedBy    User?             @relation("BatchReceivedBy", fields: [receivedById], references: [id])
  createdBy     User?             @relation("BatchCreatedBy", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("transfer_batches")
}

model SparePartRequest {
  id              String   @id @default(uuid())
  documentNumber  String   @unique
  orgId           String
  branchId        String
  requestedById   String
  status          String   @default("pending")
  urgency         String   @default("medium")
  notes           String?
  responseNotes   String?
  respondedAt     DateTime?
  respondedById   String?
  fulfilledAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items       SparePartRequestItem[]
  batches     TransferBatch[]
  requestedBy User  @relation("RequestCreatedBy", fields: [requestedById], references: [id])
  respondedBy User? @relation("RequestRespondedBy", fields: [respondedById], references: [id])

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@map("spare_part_requests")
}

model SparePartRequestItem {
  id          String    @id @default(uuid())
  requestId   String
  sparePartId String?
  partName    String
  partCode    String?
  quantity    Int
  reason      String?
  createdAt   DateTime  @default(now())

  request   SparePartRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sparePart SparePart?       @relation(fields: [sparePartId], references: [id])

  @@index([requestId])
  @@map("spare_part_request_items")
}

model ExpenseCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  categoryId  String
  amount      Decimal
  description String
  expenseDate DateTime
  receiptUrl  String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id])
  category  ExpenseCategory @relation(fields: [categoryId], references: [id])
  createdBy User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([vehicleId])
  @@index([expenseDate])
  @@index([categoryId])
  @@index([vehicleId, expenseDate])
  @@map("expenses")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model VehicleHealthScore {
  id                String   @id @default(uuid())
  vehicleId         String
  score             Decimal
  grade             String
  mileageFactor     Decimal
  maintenanceFactor Decimal
  fuelFactor        Decimal
  ageFactor         Decimal
  details           Json?
  calculatedAt      DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, calculatedAt])
  @@map("vehicle_health_scores")
}

model FuelConsumptionMetric {
  id                String   @id @default(uuid())
  vehicleId         String
  periodStart       DateTime
  periodEnd         DateTime
  avgLitersPer100km Decimal
  totalLiters       Decimal
  totalKm           Decimal
  totalCost         Decimal
  refuelCount       Int
  anomalyFlag       Boolean  @default(false)
  createdAt         DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, periodStart])
  @@map("fuel_consumption_metrics")
}

model MaintenancePrediction {
  id               String    @id @default(uuid())
  vehicleId        String
  partCategory     String
  predictedDate    DateTime
  predictedKm      Decimal?
  confidence       Decimal
  basedOnHistory   Int       @default(0)
  isAcknowledged   Boolean   @default(false)
  acknowledgedAt   DateTime?
  createdAt        DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, predictedDate])
  @@map("maintenance_predictions")
}

model Anomaly {
  id          String    @id @default(uuid())
  vehicleId   String
  type        String
  severity    String    @default("medium")
  description String
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  metadata    Json?
  detectedAt  DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, isResolved])
  @@index([detectedAt])
  @@map("anomalies")
}

model Recommendation {
  id              String    @id @default(uuid())
  vehicleId       String?
  branchId        String?
  type            String
  priority        String    @default("medium")
  title           String
  description     String
  actionUrl       String?
  estimatedSaving Decimal?
  isDismissed     Boolean   @default(false)
  dismissedAt     DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, isDismissed])
  @@index([priority, isDismissed])
  @@map("recommendations")
}

model Alert {
  id         String    @id @default(uuid())
  vehicleId  String?
  branchId   String?
  userId     String?
  type       String
  severity   String    @default("info")
  title      String
  message    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  metadata   Json?
  createdAt  DateTime  @default(now())

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([userId, isRead])
  @@index([branchId, isRead])
  @@index([createdAt])
  @@map("alerts")
}

model ArticleCode {
  id             String   @id @default(uuid())
  sparePartId    String   @unique
  code           String   @unique
  prefix         String
  sequence       Int
  organizationId String?
  generatedAt    DateTime @default(now())

  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  @@index([prefix])
  @@index([organizationId])
  @@map("article_codes")
}

model SparePartStatistic {
  id             String    @id @default(uuid())
  sparePartId    String    @unique
  totalUsed      Int       @default(0)
  totalCost      Decimal   @default(0)
  usageCount     Int       @default(0)
  lastUsedAt     DateTime?
  organizationId String?
  calculatedAt   DateTime  @default(now())

  sparePart SparePart @relation(fields: [sparePartId], references: [id])

  @@index([organizationId])
  @@map("spare_part_statistics")
}

model AIAnalysisLog {
  id               String   @id @default(uuid())
  entityType       String
  entityId         String?
  model            String   @default("gpt-4o")
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int?
  success          Boolean  @default(true)
  errorMessage     String?
  inputSummary     String?
  outputSummary    String?
  organizationId   String?
  createdAt        DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([organizationId])
  @@map("ai_analysis_logs")
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String
  filters     Json?
  data        Json
  createdById String
  createdAt   DateTime @default(now())

  createdBy User             @relation("ReportCreatedBy", fields: [createdById], references: [id])
  schedules ReportSchedule[]

  @@index([createdById])
  @@index([type])
  @@map("reports")
}

model ReportSchedule {
  id         String    @id @default(uuid())
  reportId   String
  cronExpr   String
  recipients Json      @default("[]")
  isActive   Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime  @default(now())

  report Report @relation(fields: [reportId], references: [id])

  @@index([isActive])
  @@map("report_schedules")
}

enum PlanType {
  free
  starter
  professional
  enterprise
}

enum SubscriptionStatus {
  active
  trialing
  pending
  past_due
  canceled
  expired
}

enum PaymentProvider {
  stripe
  payme
  click
  manual
}

model Plan {
  id              String   @id @default(uuid())
  name            String
  type            PlanType @unique
  priceMonthly    Decimal
  priceYearly     Decimal
  maxVehicles     Int
  maxBranches     Int
  maxUsers        Int
  features        Json     @default("[]")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  subscriptions Subscription[]
  branches      Branch[]         @relation("BranchPlan")

  @@map("plans")
}

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @unique
  planId          String
  status          SubscriptionStatus @default(trialing)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean          @default(false)
  trialEndsAt        DateTime?
  externalId         String?
  provider           PaymentProvider  @default(manual)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([status])
  @@map("subscriptions")
}

model Invoice {
  id             String          @id @default(uuid())
  subscriptionId String
  amount         Decimal
  currency       String          @default("UZS")
  status         String          @default("pending")
  provider       PaymentProvider @default(manual)
  externalId     String?
  paidAt         DateTime?
  dueDate        DateTime?
  receiptUrl     String?
  createdAt      DateTime        @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@map("invoices")
}

model Tire {
  id                 String    @id @default(uuid())
  uniqueId           String    @unique // e.g. TIRE-2024-001 (internal)
  serialCode         String    @unique // zavod kodi, e.g. 5091609750
  serialNumber       String?   // qo'shimcha seriya
  brand              String
  model              String
  size               String    // e.g. 205/55R16
  type               String    // Summer, Winter, All-season, Off-road, Spare
  dotCode            String?   // manufacturing week-year e.g. 2524

  purchaseDate       DateTime
  purchasePrice      Decimal
  supplierId         String?

  // Lifecycle tracking
  status             String    @default("in_stock")
  // in_stock | installed | returned | written_off | damaged

  // Installation info (set when installed on vehicle)
  vehicleId          String?
  installationDate   DateTime?
  position           String?   // Front-Left, Front-Right, Rear-Left, Rear-Right
  driverId           String?   // foydalanuvchi (haydovchi)
  installedMileageKm Int?      // o'rnatilgan paytdagi odometr

  // Removal info (set when removed)
  removedDate        DateTime?
  removedMileageKm   Int?      // olib olingan paytdagi odometr
  actualMileageUsed  Int?      // removedMileageKm - installedMileageKm

  // Mileage / lifecycle
  standardMileageKm  Int       @default(40000)  // norma (km)
  totalMileage       Decimal   @default(0)

  // Tread
  initialTreadDepth  Decimal?  // mm
  currentTreadDepth  Decimal?  // mm
  condition          String    @default("good")

  warrantyEndDate    DateTime?
  retiredAt          DateTime?
  disposalMethod     String?
  notes              String?

  branchId           String?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  supplier           Supplier?         @relation(fields: [supplierId], references: [id])
  vehicle            Vehicle?          @relation(fields: [vehicleId], references: [id])
  driver             User?             @relation("TireDriver", fields: [driverId], references: [id])
  tireMaintenances   TireMaintenance[]
  tireEvents         TireEvent[]
  tireDeductions     TireDeduction[]

  @@index([vehicleId])
  @@index([status])
  @@index([branchId])
  @@index([serialCode])
  @@map("tires")
}

model TireEvent {
  id             String   @id @default(uuid())
  tireId         String
  eventType      String
  // purchased | installed | removed | returned | written_off | deduction_applied
  vehicleId      String?
  driverId       String?
  mileageAtEvent Int?
  position       String?
  notes          String?
  createdById    String?
  createdAt      DateTime @default(now())

  tire      Tire  @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@index([tireId])
  @@index([eventType])
  @@map("tire_events")
}

model TireDeduction {
  id                  String    @id @default(uuid())
  tireId              String
  driverId            String?
  vehicleId           String?

  standardMileageKm   Int       // norma km (e.g. 40000)
  actualMileageKm     Int       // haqdiqatda yurilgan km
  remainingMileageKm  Int       // standardKm - actualKm
  purchasePrice       Decimal   // sotib olingan narx
  deductionPerKm      Decimal   // purchasePrice / standardKm
  deductionAmount     Decimal   // remainingKm * deductionPerKm

  reason              String?   // sabab (damaged, worn_early, lost)
  isSettled           Boolean   @default(false)
  settledAt           DateTime?
  settledNotes        String?
  notes               String?

  createdAt           DateTime  @default(now())

  tire    Tire  @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@index([tireId])
  @@index([driverId])
  @@index([isSettled])
  @@map("tire_deductions")
}

model TireMaintenance {
  id        String   @id @default(uuid())
  tireId    String
  type      String   // rotation, repair, inspection, pressure_check
  date      DateTime
  position  String?
  cost      Decimal  @default(0)
  notes     String?
  createdAt DateTime @default(now())

  tire Tire @relation(fields: [tireId], references: [id], onDelete: Cascade)

  @@index([tireId])
  @@map("tire_maintenances")
}

model SupportTicket {
  id          String   @id @default(uuid())
  ticketNumber String  @unique
  userId      String
  subject     String
  description String
  category    String   @default("technical") // technical, billing, feature_request, other
  priority    String   @default("medium")    // low, medium, high, urgent
  status      String   @default("open")      // open, in_progress, resolved, closed
  assignedTo  String?
  resolution  String?
  closedAt    DateTime?
  attachmentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id])
  replies TicketReply[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@map("support_tickets")
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  userId    String
  message   String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_replies")
}

model Warranty {
  id             String   @id @default(uuid())
  partType       String   // tire, spare_part, battery, vehicle
  partId         String   // uuid of the referenced part
  partName       String
  vehicleId      String?
  startDate      DateTime
  endDate        DateTime
  mileageLimit   Decimal?
  coverageType   String   @default("full") // full, limited, partial
  provider       String?
  notes          String?
  status         String   @default("active") // active, expiring_soon, expired, claimed

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([partType, partId])
  @@index([endDate])
  @@index([vehicleId])
  @@map("warranties")
}

model ServiceInterval {
  id              String    @id @default(uuid())
  vehicleId       String
  serviceType     String
  // oil_change | air_filter | fuel_filter | gearbox_oil | coolant | brake_fluid | timing_belt | spark_plug | brake_pads

  intervalKm      Int       // km oralig'i (masalan 5000)
  intervalDays    Int       // kun oralig'i (masalan 180)
  warningKm       Int       @default(500)  // qancha km qolsa ogohlantirilsin

  lastServiceKm   Int?      // oxirgi xizmat bajariilgan km
  lastServiceDate DateTime? // oxirgi xizmat sanasi
  nextDueKm       Int?      // keyingi xizmat km (auto-hisob)
  nextDueDate     DateTime? // keyingi xizmat sanasi (auto-hisob)

  status          String    @default("ok") // ok | due_soon | overdue
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  records         ServiceRecord[]

  @@unique([vehicleId, serviceType])
  @@index([vehicleId])
  @@index([status])
  @@map("service_intervals")
}

model ServiceRecord {
  id                String   @id @default(uuid())
  vehicleId         String
  serviceIntervalId String?
  serviceType       String
  servicedAtKm      Int
  servicedAt        DateTime
  cost              Decimal  @default(0)
  technicianName    String?
  notes             String?
  nextDueKm         Int?
  nextDueDate       DateTime?
  createdById       String?
  createdAt         DateTime @default(now())

  vehicle         Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  serviceInterval ServiceInterval? @relation(fields: [serviceIntervalId], references: [id])

  @@index([vehicleId])
  @@index([serviceType])
  @@index([servicedAt])
  @@map("service_records")
}

model Waybill {
  id                   String    @id @default(uuid())
  number               String    @unique           // avto: WB-2026-0001
  branchId             String
  vehicleId            String
  driverId             String
  status               String    @default("draft") // draft | active | completed | cancelled

  // Marshrut
  purpose              String                      // xizmat safari, yuk tashish, ...
  destination          String                      // Toshkent → Samarqand
  routeDescription     String?

  // Vaqt
  plannedDeparture     DateTime
  plannedReturn        DateTime?
  actualDeparture      DateTime?
  actualReturn         DateTime?

  // Odometr
  departureOdometer    Int?                        // km, ketishda
  returnOdometer       Int?                        // km, qaytishda
  distanceTraveled     Int?                        // avtomatik: return - departure

  // Yoqilg'i
  fuelAtDeparture      Decimal   @default(0)       // litr
  fuelIssued           Decimal   @default(0)       // litr
  fuelAtReturn         Decimal   @default(0)       // litr
  fuelConsumed         Decimal?                    // avtomatik

  // Texnik nazorat
  mechanicName         String?
  mechanicCheckedAt    DateTime?
  mechanicApproved     Boolean   @default(false)
  dispatcherName       String?
  notes                String?

  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  branch      Branch  @relation(fields: [branchId], references: [id])
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  driver      User    @relation("WaybillDriver", fields: [driverId], references: [id])
  createdBy   User?   @relation("WaybillCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
  @@index([plannedDeparture])
  @@map("waybills")
}

model FuelImport {
  id          String   @id @default(uuid())
  title       String
  month       Int      // 1-12
  year        Int
  status      String   @default("draft") // draft | confirmed
  fileType    String?  // image | pdf | excel
  sourceFile  String?
  totalRows   Int      @default(0)
  confirmedAt DateTime?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rows FuelImportRow[]

  @@index([status])
  @@index([year, month])
  @@map("fuel_imports")
}

model FuelImportRow {
  id           String    @id @default(uuid())
  importId     String
  rowNumber    Int
  refuelDate   DateTime?
  licensePlate String?
  vehicleId    String?
  waybillNo    String?
  quantityM3   Decimal   @default(0)
  pricePerUnit Decimal   @default(0)
  totalAmount  Decimal   @default(0)
  driverName      String?
  driverId        String?
  matchStatus     String    @default("unmatched") // matched | unmatched | manual
  odometerReading Decimal   @default(0)
  fuelRecordId    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  import FuelImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@map("fuel_import_rows")
}

model PromoCode {
  id              String    @id @default(uuid())
  code            String    @unique
  discountPercent Int
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("promo_codes")
}

// ─── Shina nazorati (GPS asosida) ────────────────────────────────────────────
model TireTracking {
  id          String   @id @default(uuid())
  vehicleId   String
  slotNumber  Int      // 1..12
  label       String?  // "Old chap", "Old o'ng", "Orqa 1-chap", ...
  serialCode  String?  // balon zavod kodi / raqami
  installDate DateTime
  normKm      Int      @default(50000)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, slotNumber])
  @@index([vehicleId])
  @@map("tire_tracking")
}

// ─── Dvigatel passport ───────────────────────────────────────────────────────
model EngineRecord {
  id                 String   @id @default(uuid())
  vehicleId          String
  recordType         String   // overhaul | major_repair | minor_repair | inspection
  mileage            Decimal
  date               DateTime
  description        String
  cost               Decimal  @default(0)
  nextServiceMileage Decimal?
  performedBy        String?
  notes              String?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdBy User    @relation("EngineRecordCreator", fields: [createdById], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@map("engine_records")
}

// ─── Oylik texnik tekshiruv ───────────────────────────────────────────────────
model TechInspection {
  id             String   @id @default(uuid())
  vehicleId      String
  branchId       String?
  inspectedById  String
  inspectionDate DateTime
  engineOil      String   @default("ok")   // ok | warning | critical
  coolant        String   @default("ok")
  brakes         String   @default("ok")
  transmission   String   @default("ok")
  tires          String   @default("ok")
  lights         String   @default("ok")
  exhaust        String   @default("ok")
  bodyCondition  String   @default("ok")
  overallStatus  String   @default("ok")   // ok | warning | critical
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle     Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inspectedBy User    @relation("InspectionInspectedBy", fields: [inspectedById], references: [id])

  @@index([vehicleId])
  @@index([branchId])
  @@index([inspectionDate])
  @@map("tech_inspections")
}

// ─── GPS integratsiya ─────────────────────────────────────────────────────────
model GpsCredential {
  id              String    @id @default(uuid())
  orgId           String    @unique  // Branch.organizationId ?? Branch.id (per company)
  provider        String    @default("smartgps")
  host            String    @default("http://2.smartgps.uz")
  username        String
  token           String    // Wialon token (parol saqlanmaydi)
  tokenExpiresAt  DateTime? // Token muddati tugash sanasi (TOKEN_DURATION asos)
  isActive        Boolean   @default(true)
  lastSyncAt      DateTime?
  lastSyncStatus  String?   // ok | error
  lastSyncError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("gps_credentials")
}

model GpsMileageLog {
  id          String   @id @default(uuid())
  vehicleId   String
  syncedAt    DateTime @default(now())
  gpsMileageKm Decimal
  prevMileageKm Decimal
  skipped     Boolean  @default(false)
  skipReason  String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([syncedAt])
  @@map("gps_mileage_logs")
}

model OrgSettings {
  orgId              String   @id
  oilIntervalKm      Int      @default(7000)
  oilWarningKm       Int      @default(500)
  telegramBotToken   String?
  telegramChatId     String?
  updatedAt          DateTime @updatedAt

  @@map("org_settings")
}

model BudgetPlan {
  id        String   @id @default(uuid())
  orgId     String
  branchId  String?
  year      Int
  month     Int      // 0 = yillik, 1-12 = oy
  category  String   // fuel | maintenance | expense | total
  amount    Decimal
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, year, month, category, branchId])
  @@index([orgId, year])
  @@map("budget_plans")
}

// Bitta admin → N ta qurilma (telefon/PC/planshet). Markaziy bot orqali barcha chatId'larga xabar yuboriladi.
model TelegramLink {
  id           String   @id @default(uuid())
  userId       String
  chatId       String   @unique
  deviceLabel  String?  // "Direktor telefoni", "Bosh injener PC" (optional)
  linkedAt     DateTime @default(now())
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_links")
}

// Har bir user uchun Telegram ogohlantirish sozlamalari.
model TelegramNotificationPref {
  id                String   @id @default(uuid())
  userId            String   @unique
  insurance         Boolean  @default(true)
  techInspection    Boolean  @default(true)
  oilChange         Boolean  @default(true)
  fuelAnomaly       Boolean  @default(true)
  sparePart         Boolean  @default(true)
  maintenance       Boolean  @default(true)
  monthlyInspection Boolean  @default(true)
  branchIds         String[] // bo'sh = barcha filiallar
  vehicleIds        String[] // bo'sh = barcha mashinalar
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_notification_prefs")
}

// Sozlamalar sahifasida "Telegram ulash" bosilganda beriladigan qisqa muddatli token.
// Foydalanuvchi https://t.me/<bot>?start=<token> havolasi orqali botga o'tadi.
model TelegramLinkToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("telegram_link_tokens")
}

// ─── Ehtiyot qism qaytarish ───────────────────────────────────────────────────
model SparePartReturn {
  id              String    @id @default(uuid())
  maintenanceId   String?   // qaysi ta'mirlash yozuviga bog'liq (ixtiyoriy)
  vehicleId       String?
  warehouseId     String    // qaysi ombor hisobiga qaytariladi
  branchId        String    // filial (audit uchun)
  returnedById    String    // kim qaytarmoqda
  approvedById    String?
  approvedAt      DateTime?
  rejectedReason  String?
  status          String    @default("pending_approval") // pending_approval | approved | rejected
  returnDate      DateTime  @default(now())
  reason          String    // sabab — MAJBURIY
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  maintenance  MaintenanceRecord? @relation(fields: [maintenanceId], references: [id], onDelete: SetNull)
  returnedBy   User               @relation("ReturnCreatedBy", fields: [returnedById], references: [id])
  approvedBy   User?              @relation("ReturnApprovedBy", fields: [approvedById], references: [id])
  items        SparePartReturnItem[]
  evidence     SparePartReturnEvidence[]

  @@index([status])
  @@index([branchId])
  @@index([maintenanceId])
  @@map("spare_part_returns")
}

model SparePartReturnItem {
  id          String   @id @default(uuid())
  returnId    String
  sparePartId String
  warehouseId String
  quantity    Int
  unitCost    Decimal  @default(0)
  createdAt   DateTime @default(now())

  return    SparePartReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  sparePart SparePart       @relation(fields: [sparePartId], references: [id])

  @@index([returnId])
  @@map("spare_part_return_items")
}

model SparePartReturnEvidence {
  id          String   @id @default(uuid())
  returnId    String
  fileUrl     String
  fileSizeBytes Int    @default(0)
  uploadedById String?
  createdAt   DateTime @default(now())

  return SparePartReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("spare_part_return_evidence")
}
