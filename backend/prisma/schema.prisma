generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  admin
  manager
  branch_manager
  operator
  ekohisob_user
}

enum FuelType {
  petrol
  diesel
  gas
  electric
  hybrid
}

enum VehicleStatus {
  active
  maintenance
  inactive
}

enum TransferStatus {
  pending
  approved
  shipped
  received
  cancelled
  rejected
}

model User {
  id                       String    @id @default(uuid())
  email                    String    @unique
  phone                    String?   @unique
  passwordHash             String
  fullName                 String
  role                     UserRole
  branchId                 String?
  isActive                 Boolean   @default(true)
  lastLoginAt              DateTime?
  passwordChangedAt        DateTime?
  // Email verification
  emailVerified            Boolean   @default(false)
  verificationToken        String?
  verificationTokenExpiry  DateTime?
  // Password reset
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  // 2FA (TOTP)
  twoFactorEnabled         Boolean   @default(false)
  twoFactorSecret          String?
  // Billing ceiling: super admin sets this. Admin can only select plans ≤ maxPlanType.
  maxPlanType              PlanType  @default(free)
  // Maxfiylik siyosati va ommaviy ofertani qabul qilish (GDPR-like)
  termsAcceptedAt          DateTime?
  // Onboarding (yo'riqnoma) tugatildimi
  onboardingCompletedAt    DateTime?
  // Foydalanuvchining afzal ko'rgan tili — UI, Telegram xabarlari, Excel eksport
  // uchun ishlatiladi. Mumkin qiymatlar: 'uz' | 'uz-cyrl' | 'ru' | 'zh'.
  // Default 'uz' (lotin) — orqaga moslik.
  preferredLanguage        String    @default("uz")
  // EkoHisob moduli uchun — faqat ekohisob_user rolidagi foydalanuvchilar uchun
  ekoDistrictIds           String[]  @default([])
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  branch              Branch?                   @relation("UserBranch", fields: [branchId], references: [id])
  managedBranches     Branch[]                  @relation("BranchManager")
  maintenanceRecords  MaintenanceRecord[]       @relation("PerformedBy")
  fuelRecords         FuelRecord[]              @relation("FuelCreatedBy")
  expenses            Expense[]                 @relation("ExpenseCreatedBy")
  approvedTransfers   InventoryTransfer[]       @relation("TransferApprovedBy")
  inventoryReceipts   InventoryReceipt[]        @relation("ReceiptReceivedBy")
  tokenBlacklists     TokenBlacklist[]
  assignedTires       Tire[]                    @relation("TireDriver")
  auditLogs           AuditLog[]
  notifications       Notification[]
  savedReports        Report[]                  @relation("ReportCreatedBy")
  subscription        Subscription?
  supportTickets      SupportTicket[]
  ticketReplies       TicketReply[]
  drivenWaybills      Waybill[]                 @relation("WaybillDriver")
  createdWaybills     Waybill[]                 @relation("WaybillCreatedBy")
  supplierPayments    SupplierPayment[]         @relation("SupplierPaymentCreatedBy")
  techInspections     TechInspection[]          @relation("InspectionInspectedBy")
  engineRecords       EngineRecord[]            @relation("EngineRecordCreator")
  telegramLinks       TelegramLink[]
  telegramLinkTokens  TelegramLinkToken[]
  telegramNotifPref   TelegramNotificationPref?
  shippedBatches      TransferBatch[]           @relation("BatchShippedBy")
  receivedBatches     TransferBatch[]           @relation("BatchReceivedBy")
  createdBatches      TransferBatch[]           @relation("BatchCreatedBy")
  sparePartRequests   SparePartRequest[]        @relation("RequestCreatedBy")
  respondedRequests   SparePartRequest[]        @relation("RequestRespondedBy")
  approvedMaintenance MaintenanceRecord[]       @relation("MaintenanceApprovedBy")
  sparePartReturns    SparePartReturn[]         @relation("ReturnCreatedBy")
  approvedReturns     SparePartReturn[]         @relation("ReturnApprovedBy")
  oldPartDebts        OldPartDebt[]             @relation("OldPartDebtWorker")
  approvedOldDebts    OldPartDebt[]             @relation("OldPartDebtApprover")
  archivedItems       Archive[]                 @relation("ArchiveDeletedBy")

  @@index([role])
  @@index([branchId])
  @@map("users")
}

model Warehouse {
  id             String   @id @default(uuid())
  name           String
  location       String?
  isActive       Boolean  @default(true)
  // Multi-tenant: nullable — eski (linked emas) warehouse'lar legacy holatida saqlanadi.
  // Yangi warehouse'lar yaratilganda createWarehouse caller'ning org'ini avtomatik
  // o'rnatadi. Migration backfill: Branch.warehouseId orqali eski yozuvlar uchun ham to'ldiriladi.
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branches           Branch[]
  inventory          Inventory[]
  transfersFrom      InventoryTransfer[] @relation("TransferFrom")
  transfersTo        InventoryTransfer[] @relation("TransferTo")
  maintenanceRecords MaintenanceRecord[] @relation("MaintenanceSourceWarehouse")
  maintenanceItems   MaintenanceItem[]   @relation("MaintenanceItemWarehouse")
  batchesFrom        TransferBatch[]     @relation("BatchFrom")
  batchesTo          TransferBatch[]     @relation("BatchTo")
  inventoryReceipts  InventoryReceipt[]

  @@index([organizationId])
  @@map("warehouses")
}

model Branch {
  id                String   @id @default(uuid())
  name              String
  location          String
  managerId         String?
  warehouseCapacity Decimal  @default(0)
  contactPhone      String
  isActive          Boolean  @default(true)
  warehouseId       String?
  organizationId    String?
  // Plan assigned by admin to this branch. Null = inherit admin's plan.
  planId            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  manager      User?      @relation("BranchManager", fields: [managerId], references: [id])
  warehouse    Warehouse? @relation(fields: [warehouseId], references: [id])
  plan         Plan?      @relation("BranchPlan", fields: [planId], references: [id], onDelete: SetNull)
  users        User[]     @relation("UserBranch")
  vehicles     Vehicle[]
  waybills     Waybill[]
  organization Branch?    @relation("OrgBranches", fields: [organizationId], references: [id], onDelete: SetNull)
  subBranches  Branch[]   @relation("OrgBranches")

  @@index([organizationId])
  @@map("branches")
}

model Vehicle {
  id                   String        @id @default(uuid())
  registrationNumber   String        @unique
  model                String
  brand                String
  year                 Int
  fuelType             FuelType
  branchId             String
  purchaseDate         DateTime
  mileage              Decimal       @default(0)
  engineHours          Decimal? // dvigatel soatlari (GPS dan)
  lastGpsSignal        DateTime? // oxirgi GPS signal vaqti
  gpsUnitName          String? // GPS dagi unit nomi (qo'lda bog'lash)
  oilIntervalKm        Int? // motor yog'i almashtirish intervali (km), null = org default
  // ─── Bak yoqilg'i nazorati (Wialon fuel sensor orqali, real-time) ─────
  tankCapacity         Float? // Bak hajmi (litr). null = sozlanmagan, panel-da "?" ko'rinadi
  fuelSensorName       String? // Wialon sensor nomi (default: avto-aniqlash "Топливо"/"Fuel")
  lastFuelLevel        Float? // Eng oxirgi qiymat (litr) — cache, har 30s yangilanadi
  lastFuelUpdate       DateTime? // Eng oxirgi sensor yangilanishi
  status               VehicleStatus @default(active)
  notes                String?
  insuranceExpiry      DateTime?
  techInspectionExpiry DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  branch             Branch                  @relation(fields: [branchId], references: [id])
  maintenanceRecords MaintenanceRecord[]
  fuelRecords        FuelRecord[]
  expenses           Expense[]
  healthScores       VehicleHealthScore[]
  fuelMetrics        FuelConsumptionMetric[]
  predictions        MaintenancePrediction[]
  anomalies          Anomaly[]
  recommendations    Recommendation[]
  alerts             Alert[]
  tires              Tire[]
  warranties         Warranty[]
  serviceIntervals   ServiceInterval[]
  serviceRecords     ServiceRecord[]
  waybills           Waybill[]
  engineRecords      EngineRecord[]
  techInspections    TechInspection[]
  gpsMileageLogs     GpsMileageLog[]
  tireTrackings      TireTracking[]
  fuelReadings       FuelReading[]

  @@index([branchId])
  @@index([status])
  @@index([fuelType])
  @@map("vehicles")
}

model Supplier {
  id             String   @id @default(uuid())
  organizationId String? // null = global (eski yozuvlar), tashkilotga biriktirilgan
  name           String
  contactPerson  String?
  phone          String
  email          String?
  address        String?
  paymentTerms   String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  spareParts         SparePart[]
  maintenanceRecords MaintenanceRecord[]
  fuelRecords        FuelRecord[]
  tires              Tire[]
  payments           SupplierPayment[]

  @@index([organizationId])
  @@map("suppliers")
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String
  amount      Decimal
  // 'invoice' = xarid (biz qarz bo'ldik) | 'payment' = to'lov (biz to'ladik)
  type        String   @default("payment")
  paymentDate DateTime
  note        String?
  createdById String
  createdAt   DateTime @default(now())

  supplier  Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdBy User     @relation("SupplierPaymentCreatedBy", fields: [createdById], references: [id])

  @@index([supplierId])
  @@map("supplier_payments")
}

model SparePart {
  id             String   @id @default(uuid())
  name           String
  // partCode endi per-org unique (avval global unique edi).
  // Avvalgi global unique: bir xil "BAT-001" kodini ikki tashkilot ishlata olmasdi.
  // Endi har tashkilot o'z kodlarini erkin tanlaydi, lekin org doirasida unique.
  partCode       String
  category       String
  unitPrice      Decimal
  supplierId     String
  description    String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  organizationId String? // null = global (legacy/migration'gacha), org'ga biriktirilgan
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  supplier           Supplier               @relation(fields: [supplierId], references: [id])
  inventories        Inventory[]
  maintenanceRecords MaintenanceRecord[]
  maintenanceItems   MaintenanceItem[]
  transfers          InventoryTransfer[]
  articleCode        ArticleCode?
  statistic          SparePartStatistic?
  requestItems       SparePartRequestItem[]
  returnItems        SparePartReturnItem[]
  inventoryReceipts  InventoryReceipt[]

  @@unique([organizationId, partCode], map: "spare_parts_org_partcode_key")
  @@index([organizationId])
  @@map("spare_parts")
}

model Inventory {
  id               String    @id @default(uuid())
  sparePartId      String
  warehouseId      String
  quantityOnHand   Int       @default(0)
  quantityReserved Int       @default(0)
  reorderLevel     Int       @default(1)
  lastRestockDate  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sparePart SparePart @relation(fields: [sparePartId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([sparePartId, warehouseId])
  @@index([warehouseId])
  @@index([sparePartId])
  @@map("inventory")
}

model InventoryReceipt {
  id           String   @id @default(uuid())
  sparePartId  String
  warehouseId  String
  quantity     Int
  unitPrice    Decimal  @default(0) @db.Decimal(12, 2)
  // Rasmiy = buxgalteriya orqali (schyot-faktura bilan)
  // Norasmiy = ko'chadan/naqd, hech qanday hujjatsiz
  // Default true (eski yozuvlar rasmiy deb sanaymiz)
  isOfficial   Boolean  @default(true)
  receivedById String?
  notes        String?
  createdAt    DateTime @default(now())

  sparePart  SparePart @relation(fields: [sparePartId], references: [id])
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id])
  receivedBy User?     @relation("ReceiptReceivedBy", fields: [receivedById], references: [id])

  @@index([warehouseId])
  @@index([sparePartId])
  @@index([createdAt])
  @@map("inventory_receipts")
}

model MaintenanceRecord {
  id                  String    @id @default(uuid())
  vehicleId           String
  sparePartId         String?
  quantityUsed        Int       @default(0)
  sourceWarehouseId   String?
  installationDate    DateTime
  installationMileage Int?
  cost                Decimal   @default(0)
  laborCost           Decimal   @default(0)
  workerName          String?
  paymentType         String    @default("cash")
  isPaid              Boolean   @default(true)
  // Rasmiy = buxgalteriya uchun mos (rasmiy kirim qilingan qismlar bilan)
  // Norasmiy = norasmiy qismlar bilan, dalolatnoma "Buxgalteriya uchun" variantda chiqarilmaydi
  isOfficial          Boolean   @default(true)
  supplierId          String?
  notes               String?
  performedById       String
  // Approval workflow
  status              String    @default("approved") // approved | pending_approval | rejected
  approvedById        String?
  approvedAt          DateTime?
  rejectedReason      String?
  // Yog' (moй) bo'lsa — kalit so'z orqali avtomatik aniqlanadi
  isOil               Boolean   @default(false)
  oilLiters           Float?    // Necha litr yog' ishlatilgani (ixtiyoriy)
  // Telegram OTP evidence upload
  evidenceOtpCode     String?
  evidenceOtpExpiry   DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  vehicle         Vehicle               @relation(fields: [vehicleId], references: [id])
  sparePart       SparePart?            @relation(fields: [sparePartId], references: [id])
  sourceWarehouse Warehouse?            @relation("MaintenanceSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  supplier        Supplier?             @relation(fields: [supplierId], references: [id])
  performedBy     User                  @relation("PerformedBy", fields: [performedById], references: [id])
  approvedBy      User?                 @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])
  items           MaintenanceItem[]
  evidence        MaintenanceEvidence[]
  returns         SparePartReturn[]
  oldPartDebts    OldPartDebt[]

  @@index([vehicleId])
  @@index([installationDate])
  @@index([vehicleId, installationDate])
  @@index([sparePartId])
  @@index([status])
  @@map("maintenance_records")
}

model MaintenanceEvidence {
  id            String   @id @default(uuid())
  maintenanceId String
  fileUrl       String
  fileSizeBytes Int      @default(0)
  uploadedById  String?
  createdAt     DateTime @default(now())

  maintenance MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@index([maintenanceId])
  @@map("maintenance_evidence")
}

model MaintenanceItem {
  id            String   @id @default(uuid())
  maintenanceId String
  sparePartId   String
  warehouseId   String?
  quantityUsed  Int      @default(1)
  unitCost      Decimal  @default(0)
  // Tire integration
  isTire        Boolean  @default(false)
  tireSerial    String?
  tirePosition  String?
  tireId        String? // auto-created Tire id
  createdAt     DateTime @default(now())

  maintenance MaintenanceRecord @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  sparePart   SparePart         @relation(fields: [sparePartId], references: [id])
  warehouse   Warehouse?        @relation("MaintenanceItemWarehouse", fields: [warehouseId], references: [id])

  @@index([maintenanceId])
  @@index([sparePartId])
  @@map("maintenance_items")
}

model FuelRecord {
  id              String   @id @default(uuid())
  vehicleId       String
  fuelType        FuelType
  amountLiters    Decimal
  cost            Decimal
  odometerReading Decimal
  refuelDate      DateTime
  supplierId      String?
  receiptImageUrl String?
  aiExtractedData Json?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle       Vehicle            @relation(fields: [vehicleId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  createdBy     User               @relation("FuelCreatedBy", fields: [createdById], references: [id])
  meterReadings FuelMeterReading[]

  @@index([vehicleId])
  @@index([refuelDate])
  @@index([vehicleId, refuelDate])
  @@index([supplierId])
  @@map("fuel_records")
}

// ─── Bakdagi yoqilg'i miqdori snapshot'lari ─────────────────────────────────
// Wialon fuel sensor'idan har 30s da olinadi. Tarix grafigi va sliv/zapravka
// aniqlash uchun ishlatiladi.
//
// Diqqat: tez to'lib boruvchi jadval (80 mashina × 30s = 230,400 yozuv/kun).
// Saqlash siyosati: faqat oxirgi 30 kun. Eski yozuvlar scheduler tomonidan
// o'chiriladi (delete cascade ham vehicle o'chirilganida ishlatiladi).
model FuelReading {
  id         String   @id @default(uuid())
  vehicleId  String
  level      Float // Bakdagi yoqilg'i miqdori (litr)
  capacity   Float? // Bak hajmi (litr) — snapshot vaqtidagi qiymat
  percentage Float? // level/capacity*100, oson query qilish uchun
  // Anomaliya bayrog'i — backend aniqlaydi:
  //   null  = oddiy yangilanish
  //   'theft'   = sliv (dvigatel o'chiq + yoqilg'i pasaymoqda)
  //   'refuel'  = zapravka (tez yuqori ko'tarilgan)
  //   'unrecorded_refuel' = chek yo'q lekin ko'tarilgan
  anomaly    String?
  // Anomaliya bayrog'i bilan — oldingi snapshot'dan o'zgarish (litr).
  // Sliv uchun manfiy (-35.2), zapravka uchun musbat (+50.0).
  // Tejov hisoblagichi (Savings widget) shu maydondan foyda hisobini chiqaradi.
  deltaL     Float?
  // GPS koordinatasi (Wialon lmsg.pos.y = lat, .x = lon)
  // Anomaliya kelganda xaritada "sliv shu yerda bo'ldi" deb ko'rsatish uchun.
  lat        Float?
  lon        Float?
  // Anomaliya vaqtidagi haydovchi (Waybill cross-check natijasi)
  // Waybill.driver — actualDeparture..actualReturn oraligida bo'lgan haydovchi.
  // Topilmasa null — har Vehicle har vaqt waybill ostida ishlamaydi.
  driverId   String?
  driverName String?
  capturedAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, capturedAt])
  @@index([capturedAt]) // eski yozuvlarni tozalash uchun
  @@index([anomaly]) // anomaliyalarni tez topish
  @@map("fuel_readings")
}

model FuelMeterReading {
  id              String    @id @default(uuid())
  fuelRecordId    String?
  imageUrl        String
  extractedValue  Decimal?
  confidenceScore Decimal?
  rawOcrText      String?
  processedAt     DateTime?
  status          String    @default("pending")
  createdAt       DateTime  @default(now())

  fuelRecord FuelRecord? @relation(fields: [fuelRecordId], references: [id])

  @@map("fuel_meter_readings")
}

model InventoryTransfer {
  id              String         @id @default(uuid())
  fromWarehouseId String
  toWarehouseId   String
  sparePartId     String
  quantity        Int
  transferDate    DateTime       @default(now())
  approvedById    String?
  status          TransferStatus @default(pending)
  notes           String?
  batchId         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromWarehouse Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])
  sparePart     SparePart      @relation(fields: [sparePartId], references: [id])
  approvedBy    User?          @relation("TransferApprovedBy", fields: [approvedById], references: [id])
  batch         TransferBatch? @relation(fields: [batchId], references: [id])

  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([batchId])
  @@map("inventory_transfers")
}

model TransferBatch {
  id              String    @id @default(uuid())
  documentNumber  String    @unique
  orgId           String
  fromWarehouseId String
  toWarehouseId   String
  requestId       String?
  status          String    @default("pending")
  notes           String?
  shippedAt       DateTime?
  shippedById     String?
  receivedAt      DateTime?
  receivedById    String?
  createdById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fromWarehouse Warehouse           @relation("BatchFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("BatchTo", fields: [toWarehouseId], references: [id])
  transfers     InventoryTransfer[]
  request       SparePartRequest?   @relation(fields: [requestId], references: [id])
  shippedBy     User?               @relation("BatchShippedBy", fields: [shippedById], references: [id])
  receivedBy    User?               @relation("BatchReceivedBy", fields: [receivedById], references: [id])
  createdBy     User?               @relation("BatchCreatedBy", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("transfer_batches")
}

model SparePartRequest {
  id             String    @id @default(uuid())
  documentNumber String    @unique
  orgId          String
  branchId       String
  requestedById  String
  status         String    @default("pending")
  urgency        String    @default("medium")
  notes          String?
  responseNotes  String?
  respondedAt    DateTime?
  respondedById  String?
  fulfilledAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items       SparePartRequestItem[]
  batches     TransferBatch[]
  requestedBy User                   @relation("RequestCreatedBy", fields: [requestedById], references: [id])
  respondedBy User?                  @relation("RequestRespondedBy", fields: [respondedById], references: [id])

  @@index([orgId])
  @@index([branchId])
  @@index([status])
  @@map("spare_part_requests")
}

model SparePartRequestItem {
  id          String   @id @default(uuid())
  requestId   String
  sparePartId String?
  partName    String
  partCode    String?
  quantity    Int
  reason      String?
  createdAt   DateTime @default(now())

  request   SparePartRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sparePart SparePart?       @relation(fields: [sparePartId], references: [id])

  @@index([requestId])
  @@map("spare_part_request_items")
}

model ExpenseCategory {
  id             String   @id @default(uuid())
  name           String
  description    String?
  // SaaS multi-tenant: null = legacy/global (hamma uchun), aks holda — shu tashkilot uchun
  organizationId String?
  createdAt      DateTime @default(now())

  expenses Expense[]

  @@index([organizationId])
  @@map("expense_categories")
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String
  categoryId  String
  amount      Decimal
  description String
  expenseDate DateTime
  receiptUrl  String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id])
  category  ExpenseCategory @relation(fields: [categoryId], references: [id])
  createdBy User            @relation("ExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([vehicleId])
  @@index([expenseDate])
  @@index([categoryId])
  @@index([vehicleId, expenseDate])
  @@map("expenses")
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("token_blacklist")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model VehicleHealthScore {
  id                String   @id @default(uuid())
  vehicleId         String
  score             Decimal
  grade             String
  mileageFactor     Decimal
  maintenanceFactor Decimal
  fuelFactor        Decimal
  ageFactor         Decimal
  details           Json?
  calculatedAt      DateTime @default(now())

