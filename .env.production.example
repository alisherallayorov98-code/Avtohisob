# ──────────────────────────────────────────────────────────────────────────────
# AvtoHisob — Production Environment Variables
# Bu faylni .env.production nomi bilan saqlang va to'ldiring
# HECH QACHON bu faylni git'ga push qilmang!
# ──────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=avtohisob
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE        # kamida 20 ta belgi
POSTGRES_DB=avtohisob

# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# JWT (openssl rand -hex 64 bilan generatsiya qiling)
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_64_CHAR_RANDOM_STRING

# CORS — sizning domeningiz
CORS_ORIGIN=https://avtohisob.uz
APP_URL=https://avtohisob.uz

# ─── AI (OpenAI) ──────────────────────────────────────────────────────────────
# Vedomost import va AI tahlil uchun kerak
OPENAI_API_KEY=sk-...

# ─── Email (ixtiyoriy) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sizning@gmail.com
SMTP_PASS=gmail_app_password
SMTP_FROM=AvtoHisob <noreply@avtohisob.uz>

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Ops alert (ixtiyoriy, lekin tavsiya etiladi) ──────────────────────────────
# Faqat EGAGA (sizga) — mijozlarga ko'rinmaydi. Server xatosi (5xx) va kunlik
# xulosa (foydalanuvchi/mashina soni, backup holati) shu bot orqali keladi.
# Mijoz-yo'naltirilgan botlardan (TELEGRAM_BOT_TOKEN) ALOHIDA bot bo'lishi kerak:
#   1. @BotFather'ga /newbot yozib yangi bot yarating
#   2. Botga /start yozing
#   3. https://api.telegram.org/bot<TOKEN>/getUpdates dan o'z chat_id'ingizni oling
OPS_ALERT_BOT_TOKEN=
OPS_ALERT_CHAT_ID=

# scripts/backup.sh backup holati (OK/XATO) haqida shu yerdagi qiymatlarni o'qib
# xabar beradi — yuqoridagi OPS_ALERT_* bilan bir xil qiymat kifoya.
# (backup.sh backend/.env faylidan o'qiydi, alohida sozlash shart emas)
